# powers-faust-test sandbox env vars
#
# This sandbox does NOT query WordPress. The homepage renders a static
# message only. NEXT_PUBLIC_WORDPRESS_URL must still be set so Next.js
# builds cleanly (faust.config and next.config both read it at build time),
# but no real WP backend is required.
#
# Default points at WP Engine's public Faust example WordPress so the
# scaffold's leftover infrastructure (Apollo client setup, etc.) has a
# valid hostname even though it never fires queries from index.js.

NEXT_PUBLIC_WORDPRESS_URL=https://faustexample.wpengine.com

# Not required for this sandbox since no auth / preview happens.
# When wiring real WordPress later: copy from WP admin > Settings > Faust.
# FAUST_SECRET_KEY=YOUR_PLUGIN_SECRET
